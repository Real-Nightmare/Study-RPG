# =====================================================
# STUDY RPG FRONTEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Backend API URL (base path used by the SPA to reach the API)
# For local dev: http://localhost:3010
# For production (OpsCtrl via Cloudflare Pages Functions): /api
VITE_API_URL=/api

# WebSocket URL for real-time features
# For local dev: ws://localhost:3010
# For production (OpsCtrl): wss://<your-opsctrl-backend>.opsctrl.dev
VITE_WS_URL=wss://your-backend.opsctrl.dev

# Feature Flags
VITE_ENABLE_ANALYTICS=false
