# =====================================================
# STUDY RPG FRONTEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Backend API URL (base path used by the SPA to reach the API)
VITE_API_URL=http://localhost:3010

# WebSocket URL for real-time features (optional - warned in console if unset)
VITE_WS_URL=ws://localhost:3010

# Feature Flags
VITE_ENABLE_ANALYTICS=false
