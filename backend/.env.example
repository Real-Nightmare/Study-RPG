# =============================================================================
# Study RPG Backend — Environment Variables
# Copy this file to `.env` (or `.env.local`) and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=
# Comma-separated list of allowed origins for HTTP CORS and WebSocket gateways.
# Leave empty to allow all origins (NOT recommended for production).
CORS_ORIGIN=http://localhost:5189

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# Preferred: provide a single DATABASE_URL connection string.
# Fallback: provide the individual DATABASE_* variables below.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/study_rpg
# Set to "true" to enable SSL (e.g. for managed/hosted databases).
DATABASE_SSL=false

# Fallback individual connection settings (used only if DATABASE_URL is unset)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=study_rpg

# Connection pool sizing
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis (cache + BullMQ queues)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# AI / LLM Providers
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o

# -----------------------------------------------------------------------------
# Object Storage (Blomp / S3-compatible)
# Blomp is the preferred free storage provider (up to 400GB free).
# Get your credentials from https://www.blomp.com
# -----------------------------------------------------------------------------
BLOMP_ACCOUNT_ID=
BLOMP_ACCESS_KEY_ID=
BLOMP_SECRET_ACCESS_KEY=
BLOMP_BUCKET_NAME=
BLOMP_PUBLIC_URL=
BLOMP_AUTH_URL=https://authenticate.blomp.com

# Alternative: Cloudflare R2 (also S3-compatible)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
# R2_ENDPOINT=

# Alternative: Generic S3-compatible storage
# S3_ACCOUNT_ID=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_PUBLIC_URL=
# S3_ENDPOINT=

# -----------------------------------------------------------------------------
# Admin Seeding (scripts/seed-admin.js)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=nightmare
ADMIN_NAME=Joshua Martin
ADMIN_DEFAULT_PASSWORD=N1GHTMAREISGoD@123
