# =====================================================
# STUDYIELD BACKEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Application
NODE_ENV=development
PORT=3010
API_PREFIX=api/v1
LOG_LEVEL=debug

# Application URLs
APP_URL=http://localhost:3010
FRONTEND_URL=http://localhost:5189
API_URL=http://localhost:3010/api/v1

# =====================================================
# JWT CONFIGURATION
# =====================================================

JWT_ACCESS_SECRET=your_jwt_access_secret_min32chars_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min32chars_change_me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# =====================================================
# DATABASE (PostgreSQL + pgvector)
# =====================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=studyield_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =====================================================
# REDIS CACHE
# =====================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# =====================================================
# DEFAULT ADMIN ACCOUNT
# =====================================================

ADMIN_USERNAME=Nightmare
ADMIN_NAME=Joshua Martin
ADMIN_DEFAULT_PASSWORD=N1GHTMAREISGoD@123

# =====================================================
# AWS SERVICES
# =====================================================

AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# =====================================================
# CLOUDFLARE R2 STORAGE (S3-compatible)
# =====================================================

R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=studyield-dev
R2_PUBLIC_URL=https://cdn-dev.studyield.com

# =====================================================
# AI SERVICES (OpenRouter / managed providers)
# =====================================================

OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# OpenAI Direct (optional, for embeddings)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =====================================================
# WEB SEARCH (for Research feature)
# =====================================================

TAVILY_API_KEY=your-tavily-api-key
SERPER_API_KEY=your-serper-api-key

# =====================================================
# CODE SANDBOX (Python execution)
# =====================================================

CODE_SANDBOX_URL=http://localhost:8080
CODE_SANDBOX_API_KEY=your-sandbox-api-key
CODE_SANDBOX_TIMEOUT=30000

# E2B Sandbox (alternative)
E2B_API_KEY=your_e2b_api_key

# =====================================================
# RATE LIMITING
# =====================================================

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# =====================================================
# CORS (Cloudflare Pages origin)
# =====================================================

CORS_ORIGIN=https://studyield.pages.dev

# =====================================================
# PUSH NOTIFICATIONS (Firebase)
# =====================================================

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# =====================================================
# FILE STORAGE
# =====================================================

UPLOAD_DESTINATION=./uploads
MAX_FILE_SIZE=10485760
TEMP_FILES_DIR=./temp
