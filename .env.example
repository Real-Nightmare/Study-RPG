# =============================================================================
# Study RPG Backend — Environment Variables
# Copy this file to `.env` (or `.env.local`) and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=
# Comma-separated list of allowed origins for HTTP CORS and WebSocket gateways.
# Leave empty to allow all origins (NOT recommended for production).
CORS_ORIGIN=http://localhost:5189

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# In production on OpsCtrl, DATABASE_URL is auto-injected.
# For local development, uncomment and fill in:
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/study_rpg
# Set to "true" to enable SSL (required for Supabase, managed DBs).
DATABASE_SSL=false

# Fallback individual connection settings (used only if DATABASE_URL is unset)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=study_rpg

# Connection pool sizing
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis (cache + BullMQ queues)
# In production on OpsCtrl, REDIS_URL is auto-injected.
# For local development, uncomment and fill in:
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# AI / LLM Providers
# -----------------------------------------------------------------------------
# OpenRouter (primary gateway)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o

# OpenAI (direct fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# Ollama Cloud (OpenAI-compatible, no CC for local models)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/api/v1
OLLAMA_MODEL=llama3.1:8b

# Groq (fallback)
GROQ_API_KEY=

# Together AI (fallback)
TOGETHER_API_KEY=

# NAVY AI (fallback)
NAVY_API_KEY=

# -----------------------------------------------------------------------------
# Web Search Providers (research module)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# Code Sandbox
# -----------------------------------------------------------------------------
CODE_SANDBOX_URL=
CODE_SANDBOX_API_KEY=
CODE_SANDBOX_TIMEOUT=10000

# -----------------------------------------------------------------------------
# Object Storage (S3-compatible providers, no CC required)
# Priority: Dark Storage > Synclyz > Backblaze B2 > Blomp (Swift) > Local
# -----------------------------------------------------------------------------

# Option 1: Dark Storage (5GB free, no CC)
S3_ACCOUNT_ID=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=
S3_ENDPOINT=https://s3.darkstorage.io

# Option 2: Synclyz (10GB free, no CC)
# S3_ACCOUNT_ID=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_PUBLIC_URL=
# S3_ENDPOINT=https://s3.synclyz.com

# Option 3: Backblaze B2 (10GB free, no CC)
# S3_ACCOUNT_ID=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_PUBLIC_URL=
# S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com

# Option 4: Blomp (OpenStack Swift API, 400GB free, no CC)
# BLOMP_ACCOUNT_ID=
# BLOMP_ACCESS_KEY_ID=
# BLOMP_SECRET_ACCESS_KEY=
# BLOMP_BUCKET_NAME=
# BLOMP_PUBLIC_URL=
# BLOMP_AUTH_URL=https://authenticate.blomp.com/v2.0/

# -----------------------------------------------------------------------------
# Admin Seeding (scripts/seed-admin.js)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=nightmare
ADMIN_NAME=Joshua Martin
ADMIN_DEFAULT_PASSWORD=N1GHTMAREISGoD@123
